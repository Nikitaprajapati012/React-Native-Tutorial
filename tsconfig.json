{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "*": ["*", "src/*"]
    }
  },
  "include": [
    "index.js",
    "App.*",
    "src/**/*",
    "__tests__/**/*",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["**/node_modules", "**/Pods"]
}
